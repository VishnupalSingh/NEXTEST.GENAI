# Get your FREE Gemini API key at: https://aistudio.google.com
# No credit card required — generous free tier included
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Set to 'true' to print Playwright MCP server stderr logs
# GENIE_DEBUG=true

# ─── Model selection (all optional; default: gemini-2.5-flash) ────────────────
# GENIE_MODEL=gemini-2.5-flash             # default model for every call
# GENIE_GENERATION_MODEL=gemini-2.5-pro    # NL test generation (favour quality)
# GENIE_HEALING_MODEL=gemini-2.5-flash     # locator self-healing (favour cost)
# GENIE_AGENT_MODEL=gemini-2.5-flash       # autonomous agent loop
# GENIE_REPORT_MODEL=gemini-2.5-flash      # end-of-run summary

# ─── Token / cost controls (optional) ────────────────────────────────────────
# GENIE_MAX_OUTPUT_TOKENS=2048
# GENIE_TEMPERATURE=0.2
# GENIE_DOM_MAX_CHARS=6000                 # max distilled-DOM chars sent when healing
# GENIE_MAX_REPAIR_ATTEMPTS=1              # LLM repair attempts for specs that fail typecheck

# ─── Reliability (optional) ───────────────────────────────────────────────────
# GENIE_MAX_RETRIES=3                      # retries on transient 429/503/network errors
# GENIE_RETRY_BASE_MS=500                  # base backoff delay (grows exponentially)

# ─── Logging (optional) ───────────────────────────────────────────────────────
# GENIE_LOG_LEVEL=info                     # debug | info | warn | error | silent

# ─── Video recording (optional; OFF by default) ──────────────────────────────
# Recording needs the Playwright ffmpeg binary: `npx playwright install ffmpeg`.
# GENIE_VIDEO=off                          # off | on | retain-on-failure | on-first-retry

# ─── Trace capture (optional) ─────────────────────────────────────────────────
# Traces open from the HTML report (step timeline + before/after DOM snapshots).
# GENIE_TRACE=retain-on-failure            # on | off | retain-on-failure | on-first-retry

# ─── Agent / MCP tuning (optional) ────────────────────────────────────────────
# GENIE_AGENT_MAX_STEPS=20
# GENIE_MCP_TIMEOUT_MS=30000
# GENIE_MCP_STARTUP_MS=600

# ─── Paths (optional) ─────────────────────────────────────────────────────────
# GENIE_REPORTS_DIR=reports
# GENIE_HEAL_CACHE=reports/healed-locators.json

# ─── Application Under Test (config/targets.json) ─────────────────────────────
# Select which environment block in config/targets.json to drive. Defaults to
# the file's "defaultEnv". Tests use use.baseURL, so page.goto('/') is relative.
# GENIE_ENV=staging
# GENIE_TARGETS_FILE=config/targets.json   # override the targets file location

# ─── Credentials for authenticated environments ──────────────────────────────
# targets.json references these BY NAME (usernameEnv/passwordEnv). Real secrets
# live ONLY here / in CI secrets — never in the committed JSON.
# STAGING_USERNAME=
# STAGING_PASSWORD=
# PROD_USERNAME=
# PROD_PASSWORD=
